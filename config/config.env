# Self-Adaptive Digital Twin - Pi Configuration Template
# Copy this to config/config.env and adjust values for your deployment

# ============================================================================
# BACKEND API CONFIGURATION
# ============================================================================
# URL of the Digital Twin backend server
# For local network: http://192.168.x.x:8000
# For localhost: http://localhost:8000
BACKEND_HOST=http://localhost:8000

# API authentication key (if required by backend)
BACKEND_API_KEY=

# ============================================================================
# NODE IDENTIFICATION
# ============================================================================
# Unique identifier for this node in the system
NODE_ID=1

# Human-readable name for this node
NODE_NAME=demo-board-01

# ============================================================================
# HARDWARE CONFIGURATION
# ============================================================================
# GPIO pin for temperature sensor (BCM numbering)
# Common: 17 (GPIO 11), 4 (GPIO 7)
TEMP_SENSOR_PIN=17

# GPIO pin for fan control PWM signal
# Common: 27 (GPIO 13), 22 (GPIO 15)
FAN_CONTROL_PIN=27

# Polling interval for sensor readings (seconds)
# Primary key used by agent.py
SENSOR_INTERVAL_SECONDS=60

# Legacy alias (optional): agent.py also accepts this for backward compatibility
# SENSOR_POLL_INTERVAL=10

# ============================================================================
# EXPERIMENT CONFIGURATION
# ============================================================================
# Which experiment to run
# Options: E1_candidate_selection, E2_accuracy, E3_learning, E4_proactive, E5_cost_optimization
EXPERIMENT_MODE=E1_candidate_selection

# Duration of each experiment cycle (seconds)
# E1: 3600 (1 hour)
# E2: 7200 (2 hours)
# E3: 14400 (4 hours)
# E4: 7200 (2 hours)
# E5: 3600 (1 hour)
EXPERIMENT_DURATION=3600

# Enable fault injection for testing adaptation
# Set to 'true' to inject faults, 'false' to run normal
FAULT_INJECTION_ENABLED=true

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file location
LOG_FILE=/home/pi/dt-experiments/logs/experiment.log

# ============================================================================
# ADVANCED OPTIONS
# ============================================================================
# Temperature threshold for alarm (degrees C)
TEMP_THRESHOLD=35

# CPU frequency scaling (optional) - helps with thermal management
# Set to max frequency for performance, or lower for efficiency
# MAX_CPU_FREQ=2000

# GPU memory (MB) - reduce if not needed to improve thermal performance
# GPU_MEM=64
